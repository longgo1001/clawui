{
  "title": "ClawUI - Linux GUI Automation",
  "tagline": "AI-driven GUI automation for Linux (Wayland/X11/CDP)",
  "core_modules": [
    "screenshot",
    "atspi_helper",
    "x11_helper",
    "cdp_helper",
    "perception",
    "actions",
    "agent",
    "backends",
    "vision_backend",
    "query",
    "main"
  ],
  "backends": {
    "ai": ["Claude", "OpenAI", "Ollama", "Gemini", "AnyRouter"],
    "perception": ["AT-SPI", "X11", "CDP", "Marionette"],
    "execution": ["xdotool", "ydotool", "CDP", "AT-SPI actions"]
  },
  "supported_models": [
    "claude-3-7-sonnet-20250219",
    "gpt-4o",
    "llava:7b (via Ollama)",
    "gemini-2.5-pro"
  ],
  "quick_start": {
    "install": "pip install -r requirements.txt",
    "run": "python3 -m skills.gui-automation.main run \"Open Firefox and visit github.com\"",
    "test": "python3 test_e2e.py"
  }
}
